{
  "name": "formular",
  "version": "4.0.0-alpha.4",
  "author": {
    "name": "Pavel Ivanov",
    "email": "grammka@gmail.com"
  },
  "description": "Small, type-safe form library for React. State lives outside the render tree; components subscribe only to the slice they care about.",
  "homepage": "https://github.com/pavelivanov/formular#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavelivanov/formular.git"
  },
  "bugs": {
    "url": "https://github.com/pavelivanov/formular/issues"
  },
  "keywords": [
    "form",
    "forms",
    "react",
    "hooks",
    "validation",
    "typescript"
  ],
  "license": "ISC",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "size": "size-limit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build && npm run test && npm run size"
  },
  "size-limit": [
    {
      "name": "ESM entry (everything)",
      "path": "dist/index.js",
      "limit": "6 kB"
    },
    {
      "name": "CJS entry (everything)",
      "path": "dist/index.cjs",
      "limit": "6.5 kB"
    },
    {
      "name": "Tree-shaken core (Form + Provider + hooks)",
      "path": "dist/index.js",
      "import": "{ Form, useFieldRegister, useFormState, FormContextProvider }",
      "limit": "4.5 kB"
    }
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^11.2.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
